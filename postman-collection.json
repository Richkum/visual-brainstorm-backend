{
  "info": {
    "name": "Visual Brainstorm Backend API",
    "description": "API collection for testing authentication and canvas functionality",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpassword123\",\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "http://localhost:3006/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3006",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"testpassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3006/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3006",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3006/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3006",
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Canvas",
      "item": [
        {
          "name": "Get Canvas State",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/canvas/{{room_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["canvas", "{{room_id}}"]
            }
          }
        },
        {
          "name": "Update Canvas (Draw)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"line\",\n  \"startX\": 100,\n  \"startY\": 100,\n  \"endX\": 200,\n  \"endY\": 200,\n  \"color\": \"#000000\",\n  \"width\": 2\n}"
            },
            "url": {
              "raw": "http://localhost:3000/canvas/{{room_id}}/draw",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["canvas", "{{room_id}}", "draw"]
            }
          }
        },
        {
          "name": "Clear Canvas",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/canvas/{{room_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["canvas", "{{room_id}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "room_id",
      "value": "test-room",
      "type": "string"
    }
  ]
}
