{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/visual-brainstorm-backend/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/visual-brainstorm-backend/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/visual-brainstorm-backend",
  "projects": {
    "auth-service": {
      "type": "application",
      "root": "apps/auth-service",
      "entryFile": "main",
      "sourceRoot": "apps/auth-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth-service/tsconfig.app.json"
      }
    },
    "canvas-service": {
      "type": "application",
      "root": "apps/canvas-service",
      "entryFile": "main",
      "sourceRoot": "apps/canvas-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/canvas-service/tsconfig.app.json"
      }
    },
    "chat-service": {
      "type": "application",
      "root": "apps/chat-service",
      "entryFile": "main",
      "sourceRoot": "apps/chat-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/chat-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "dto": {
      "type": "library",
      "root": "libs/dto",
      "entryFile": "index",
      "sourceRoot": "libs/dto/src",
      "compilerOptions": {
        "tsConfigPath": "libs/dto/tsconfig.lib.json"
      }
    },
    "gateway-api": {
      "type": "application",
      "root": "apps/gateway-api",
      "entryFile": "main",
      "sourceRoot": "apps/gateway-api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway-api/tsconfig.app.json"
      }
    },
    "visual-brainstorm-backend": {
      "type": "application",
      "root": "apps/visual-brainstorm-backend",
      "entryFile": "main",
      "sourceRoot": "apps/visual-brainstorm-backend/src",
      "compilerOptions": {
        "tsConfigPath": "apps/visual-brainstorm-backend/tsconfig.app.json"
      }
    }
  }
}